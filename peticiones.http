### Crear un servicio de Corte de Pelo
POST http://localhost:8080/api/servicios
Content-Type: application/json

{
  "nombre": "TEST",
  "descripcion": "TEST",
  "precio": 25.00,
  "duracion": 20
}

### Crear un usuario
POST http://localhost:8080/api/usuarios
Content-Type: application/json

{
  "nombre": "Renata Segovia",
  "email": "segoviarenata2017@gmail.com",
  "telefono": "989689123",
  "password": "password123",
  "fecha_registro": "2026-03-18"
}

### Agendar una Cita
POST http://localhost:8080/api/citas
Content-Type: application/json

{
  "usuario": {
    "id_usuario": 1
  },
  "servicio": {
    "id_servicio": 3
  },
  "fecha_hora": "2026-03-19T08:30:00"
}

### Obtener lista de usuarios

GET http://localhost:8080/api/usuarios

### Obtener un servicio por ID
GET http://localhost:8080/api/servicios/5

### Actualizar un servicio
PUT http://localhost:8080/api/servicios/5
Content-Type: application/json

{

  "nombre": "Peinado premium hombre",
    "descripcion": "Peinado con secador y gomina",
    "precio": 20.00,
    "duracion": 20

}

### Eliminar un servicio
DELETE http://localhost:8080/api/servicios/5

### Obtener usuarios por ID
GET http://localhost:8080/api/usuarios/4

### Actualizar un usuario
PUT http://localhost:8080/api/usuarios/3
Content-Type: application/json

{

"password": "password123"
}

### Eliminar un usuario
DELETE http://localhost:8080/api/usuarios/4

### Obtener citas por ID
GET http://localhost:8080/api/citas/4

### Actualizar una cita
PUT http://localhost:8080/api/citas/4
Content-Type: application/json

{
  "usuario": {
    "id_usuario": 2
  },
  "servicio": {
    "id_servicio": 1
  },
  "fecha_hora": "2026-03-18T19:30:00",
  "estado": "ANULADA"
}

### Eliminar una cita
DELETE http://localhost:8080/api/citas/5

### Login como ADMIN (guarda el token para las siguientes peticiones)
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "edu92seg@gmail.com",
  "password": "password123"
}

> {%
    client.global.set("token", response.body.token);
%}

### Cambiar el rol de un usuario a ADMIN (requiere sesion ADMIN)
PATCH http://localhost:8080/api/usuarios/3/rol
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rol": "ADMIN"
}

### Cambiar el rol de un usuario a USER (degradar)
PATCH http://localhost:8080/api/usuarios/3/rol
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rol": "USER"
}

##############################################
# FASE 2 — paginacion, disponibilidad, reactivar
# (todas las de citas/usuarios requieren Authorization)
##############################################

### Listar citas paginado (ADMIN ve todas, USER solo las suyas)
GET http://localhost:8080/api/citas?page=0&size=20&sort=fechaHora,desc
Authorization: Bearer {{token}}

### Consultar disponibilidad de horarios para un servicio en una fecha
GET http://localhost:8080/api/citas/disponibilidad?fecha=2026-06-15&idServicio=1
Authorization: Bearer {{token}}

### Agendar una cita (formato real del DTO: usuarioId/servicioId/fechaHora)
POST http://localhost:8080/api/citas
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "usuarioId": 1,
  "servicioId": 1,
  "fechaHora": "2026-06-15T10:00:00"
}

### Listar usuarios paginado (solo activos, por defecto) — solo ADMIN
GET http://localhost:8080/api/usuarios?page=0&size=20&sort=nombre,asc
Authorization: Bearer {{token}}

### Listar usuarios incluyendo los desactivados — solo ADMIN
GET http://localhost:8080/api/usuarios?incluirInactivos=true
Authorization: Bearer {{token}}

### Reactivar un usuario desactivado — solo ADMIN
PATCH http://localhost:8080/api/usuarios/4/activar
Authorization: Bearer {{token}}

